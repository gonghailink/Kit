{
  "name": "bookmarks-remix",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "wrangler pages dev ./build/client",
    "typecheck": "react-router typegen && tsc",
    "deploy": "npm run build && wrangler pages deploy ./build/client",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply bookmarks-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply bookmarks-db --remote",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "setup": "node scripts/setup.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@react-router/cloudflare": "^7.13.1",
    "@react-router/dev": "^7.13.1",
    "@react-router/fs-routes": "^7.13.1",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "isbot": "^5.1.17",
    "jose": "^6.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^9.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "chalk": "^5.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ora": "^8.2.0",
    "postcss": "^8.4.49",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.4.1",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^3.93.0"
  }
}
